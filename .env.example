# Anthropic API key — required for the AI workout assistant (/api/assistant)
ANTHROPIC_API_KEY=sk-ant-...

# Bearer token for API auth — set to a random string (e.g. openssl rand -hex 32)
# If unset, the API is open (fine for local dev; required for production)
FITLOCAL_API_KEY=

# Port the production server listens on (default: 3001)
PORT=3001

# Absolute path to the SQLite database file (default: <repo-root>/fitlocal.db)
# DATABASE_PATH=/path/to/fitlocal.db

# MyFitnessPal integration (optional — used by the iOS Shortcut health sync)
MFP_USERNAME=
MFP_SESSION_COOKIE=
